%%% =============================================================================
%%% $module  —  Model for the `$table` table
%%%
%%% Generated by cowboy-up.
%%%
%%% find/1:
%%%   $module:find(Id)
%%%   $module:find({column, Value})
%%%
$association_doc%%% =============================================================================
-module($module).

$exports

-define(TABLE,  "$table").
-define(FIELDS, "$sql_fields").

%% ---------------------------------------------------------------------------
%% all/0
%% ---------------------------------------------------------------------------
all() ->
    {ok, Rows} = ${app_name}_db:q(
        "SELECT " ?FIELDS " FROM " ?TABLE " ORDER BY id"
    ),
    [to_map(R) || R <- Rows].

%% ---------------------------------------------------------------------------
%% find/1
%%   find(Id)              -> {ok, Map} | {error, not_found}
%%   find({Column, Value}) -> {ok, [Map, ...]} | {error, not_found}
%% ---------------------------------------------------------------------------
find(Id) when is_integer(Id); is_binary(Id) ->
    case ${app_name}_db:q(
        "SELECT " ?FIELDS " FROM " ?TABLE " WHERE id = ?1 LIMIT 1", [Id]
    ) of
        {ok, [Row]} -> {ok, to_map(Row)};
        {ok, []}    -> {error, not_found}
    end;

find({Column, Value}) when is_atom(Column) ->
    Col = atom_to_list(Column),
    case ${app_name}_db:q(
        "SELECT " ?FIELDS " FROM " ?TABLE " WHERE " ++ Col ++ " = ?1", [Value]
    ) of
        {ok, []}   -> {error, not_found};
        {ok, Rows} -> {ok, [to_map(R) || R <- Rows]}
    end.

%% ---------------------------------------------------------------------------
%% create/1
%% ---------------------------------------------------------------------------
create(Attrs) ->
    case ${app_name}_db:exec(
        "INSERT INTO " ?TABLE " ($insert_cols) VALUES ($insert_placeholders)",
        [$insert_args]
    ) of
        ok          -> last_insert_id();
        {error,_}=E -> E
    end.

%% ---------------------------------------------------------------------------
%% update/2
%% ---------------------------------------------------------------------------
update(Id, Attrs) ->
    ${app_name}_db:exec(
        "UPDATE " ?TABLE " SET $update_set WHERE id = ?$id_pos",
        [$update_args,
         Id]
    ).

%% ---------------------------------------------------------------------------
%% delete/1
%% ---------------------------------------------------------------------------
delete(Id) ->
    ${app_name}_db:exec(
        "DELETE FROM " ?TABLE " WHERE id = ?1", [Id]
    ).

%% ---------------------------------------------------------------------------
%% to_map/1 — esqlite 0.8.x returns rows as lists, not tuples
%% ---------------------------------------------------------------------------
to_map([$var_list]) ->
    #{$map_body
     }.

%% ---------------------------------------------------------------------------
%% Internal
%% ---------------------------------------------------------------------------
last_insert_id() ->
    case ${app_name}_db:q("SELECT last_insert_rowid()") of
        {ok, [[Id]]} -> {ok, Id};
        _            -> ok
    end.

$association_functions
