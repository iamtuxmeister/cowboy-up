%%% =============================================================================
%%% ${app_name}_migrations — Migration registry
%%%
%%% AUTO-GENERATED by cowboy-up. Do not edit manually.
%%% Re-generated whenever you run: cowboy-up model or cowboy-up model add-field
%%%
%%% Add a migration:
%%%   cowboy-up model MyModel table field:type
%%%   cowboy-up model add-field MyModel field:type
%%% =============================================================================
-module(${app_name}_migrations).

-export([all/0]).

%% Returns all migration modules in version order.
%% ${app_name}_db calls this at startup to discover what to run.
all() ->
    [
$migration_list
    ].
