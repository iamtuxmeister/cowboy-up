%%% Database abstraction — SQLite backend (esqlite 0.8.x)
%%% Switch to postgres by changing {db_backend, postgres} in sys.config
%%% and uncommenting epgsql/poolboy in rebar.config.
-module(${app_name}_db).

-export([init/0, close/0, q/1, q/2, exec/1, exec/2]).

init() ->
    case backend() of
        sqlite   -> init_sqlite();
        postgres -> init_postgres()
    end.

close() ->
    case backend() of
        sqlite   -> esqlite3:close(conn());
        postgres -> ok
    end.

q(Sql)         -> q(Sql, []).
q(Sql, Params) ->
    case backend() of
        sqlite   -> sqlite_q(Sql, Params);
        postgres -> {error, postgres_not_configured}
    end.

exec(Sql)         -> exec(Sql, []).
exec(Sql, Params) ->
    case backend() of
        sqlite   -> sqlite_exec(Sql, Params);
        postgres -> {error, postgres_not_configured}
    end.

%% --- SQLite ----------------------------------------------------------------

init_sqlite() ->
    {ok, Cfg} = application:get_env($app_name, sqlite),
    Path = proplists:get_value(path, Cfg, "priv/db/${app_name}.db"),
    ok   = filelib:ensure_dir(Path),
    {ok, Db} = esqlite3:open(Path),
    persistent_term:put({${app_name}_db, conn}, Db),
    run_migrations(Db),
    ok.

conn() -> persistent_term:get({${app_name}_db, conn}).

sqlite_q(Sql, Params) ->
    case esqlite3:q(conn(), Sql, Params) of
        Rows when is_list(Rows) -> {ok, Rows};
        {error, _} = E          -> E
    end.

sqlite_exec(Sql, []) ->
    case esqlite3:exec(conn(), Sql) of
        ok             -> ok;
        {error, _} = E -> E
    end;
sqlite_exec(Sql, Params) ->
    case esqlite3:q(conn(), Sql, Params) of
        Rows when is_list(Rows) -> ok;
        {error, _} = E          -> E
    end.

%% --- PostgreSQL stub -------------------------------------------------------

init_postgres() ->
    error(postgres_backend_not_configured).

%% --- Migrations ------------------------------------------------------------
%%
%% Migrations are Erlang modules in src/migrations/, each exporting:
%%   version/0  -> string()   e.g. "20260101_001_create_example"
%%   up/0       -> string() | [string()]  one or more SQL statements
%%
%% Modules are discovered via the 'migrations' attribute registered at
%% compile time by each migration module. They run in version-sorted order
%% and each runs exactly once, tracked in schema_migrations.
%%
%% To add a migration:
%%   cowboy-up model add-field <Model> <field:type>
%%   — or —
%%   create src/migrations/YYYYMMDD_NNN_description.erl manually

run_migrations(Db) ->
    esqlite3:exec(Db,
        "CREATE TABLE IF NOT EXISTS schema_migrations ("
        "  version    TEXT PRIMARY KEY,"
        "  applied_at TEXT DEFAULT (datetime('now'))"
        ");"),
    Modules  = discover_migrations(),
    Sorted   = lists:sort(fun(A, B) -> A:version() =< B:version() end, Modules),
    lists:foreach(fun(Mod) -> apply_migration(Db, Mod) end, Sorted).

apply_migration(Db, Mod) ->
    Vsn = Mod:version(),
    Rows = esqlite3:q(Db,
        "SELECT version FROM schema_migrations WHERE version = ?1",
        [Vsn]),
    case Rows of
        [] ->
            Sql = Mod:up(),
            Statements = case is_list(Sql) andalso not io_lib:char_list(Sql) of
                true  -> Sql;   %% list of SQL strings
                false -> [Sql]  %% single SQL string
            end,
            lists:foreach(fun(S) -> ok = esqlite3:exec(Db, S) end, Statements),
            esqlite3:q(Db,
                "INSERT INTO schema_migrations (version) VALUES (?1)",
                [Vsn]),
            error_logger:info_msg("[db] Applied migration: ~s~n", [Vsn]);
        _ ->
            ok
    end.

%% Discover all migration modules for this app.
%% We scan the ebin directory for beam files whose names look like migrations
%% (YYYYMMDD_NNN_*) and load them before checking attributes — lazy loading
%% means they may not be in code:all_loaded() yet at startup.
discover_migrations() ->
    App     = $app_name,
    EbinDir = code:lib_dir($app_name, ebin),
    Beams   = filelib:wildcard("????????_???_*.beam", EbinDir),
    Modules = [list_to_atom(filename:rootname(B)) || B <- Beams],
    %% Ensure each is loaded
    lists:foreach(fun(Mod) ->
        case code:is_loaded(Mod) of
            false -> code:load_file(Mod);
            _     -> ok
        end
    end, Modules),
    [Mod || Mod <- Modules, is_migration_for(Mod, App)].

is_migration_for(Mod, App) ->
    case catch Mod:module_info(attributes) of
        Attrs when is_list(Attrs) ->
            %% -migration(app_name). produces {migration, app_name} in attributes
            lists:member({migration, App}, Attrs);
        _ ->
            false
    end.

backend() ->
    application:get_env($app_name, db_backend, sqlite).
