%%% Database abstraction — PostgreSQL backend (epgsql + poolboy)
%%%
%%% Configure in config/sys.config:
%%%   {db_backend, postgres},
%%%   {postgres, [
%%%       {host,      "localhost"},
%%%       {port,      5432},
%%%       {database,  "$app_name"},
%%%       {user,      "$app_name"},
%%%       {password,  "secret"},
%%%       {pool_size, 5}
%%%   ]}
%%%
%%% Create the database before starting:
%%%   createdb $app_name
-module(${app_name}_db).

-export([init/0, close/0, q/1, q/2, exec/1, exec/2]).

-define(POOL, ${app_name}_pg_pool).

init()  -> init_postgres().
close() -> poolboy:stop(?POOL).

q(Sql)         -> q(Sql, []).
q(Sql, Params) -> pg_q(Sql, Params).

exec(Sql)         -> exec(Sql, []).
exec(Sql, Params) -> pg_exec(Sql, Params).

%% --- PostgreSQL ------------------------------------------------------------

init_postgres() ->
    {ok, Cfg}  = application:get_env($app_name, postgres),
    Host       = proplists:get_value(host,      Cfg, "localhost"),
    Port       = proplists:get_value(port,      Cfg, 5432),
    Database   = proplists:get_value(database,  Cfg, "$app_name"),
    User       = proplists:get_value(user,      Cfg, "$app_name"),
    Password   = proplists:get_value(password,  Cfg, ""),
    PoolSize   = proplists:get_value(pool_size, Cfg, 5),

    PoolArgs   = [{name,           {local, ?POOL}},
                  {worker_module,  ${app_name}_pg_worker},
                  {size,           PoolSize},
                  {max_overflow,   2}],
    WorkerArgs = [{host,     Host},
                  {port,     Port},
                  {database, Database},
                  {username, User},
                  {password, Password}],

    {ok, _} = poolboy:start_link(PoolArgs, WorkerArgs),
    run_migrations(),
    ok.

pg_q(Sql, Params) ->
    poolboy:transaction(?POOL, fun(Worker) ->
        ${app_name}_pg_worker:q(Worker, Sql, Params)
    end).

pg_exec(Sql, Params) ->
    poolboy:transaction(?POOL, fun(Worker) ->
        ${app_name}_pg_worker:exec(Worker, Sql, Params)
    end).

%% --- Migrations ------------------------------------------------------------

run_migrations() ->
    Mod = list_to_atom(atom_to_list($app_name) ++ "_migrations"),
    case code:ensure_loaded(Mod) of
        {module, Mod} ->
            Migrations = Mod:all(),
            Sorted     = lists:sort(
                fun(A, B) -> A:version() =< B:version() end,
                Migrations),
            ensure_migrations_table(),
            lists:foreach(fun apply_migration/1, Sorted);
        {error, _} ->
            error_logger:warning_msg(
                "[db] ~p not found — no migrations will run.~n", [Mod])
    end.

ensure_migrations_table() ->
    exec("CREATE TABLE IF NOT EXISTS schema_migrations ("
         "  version    TEXT PRIMARY KEY,"
         "  applied_at TIMESTAMPTZ DEFAULT NOW()"
         ")").

apply_migration(Mod) ->
    Vsn = Mod:version(),
    case q("SELECT version FROM schema_migrations WHERE version = $$1", [Vsn]) of
        {ok, []} ->
            Statements = case Mod:up() of
                S when is_list(S), not is_integer(hd(S)) -> S;
                S -> [S]
            end,
            lists:foreach(fun(Stmt) -> ok = exec(Stmt) end, Statements),
            exec("INSERT INTO schema_migrations (version) VALUES ($$1)", [Vsn]),
            error_logger:info_msg("[db] Applied migration: ~s~n", [Vsn]);
        {ok, _} ->
            ok
    end.
