<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About — {{app_name}}</title>
    <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>
    <header class="site-header">
        <nav class="nav">
            <a class="nav-brand" href="/">{{app_name}}</a>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/about" class="active">About</a></li>
            </ul>
        </nav>
    </header>
    <main class="site-main">
        <div class="container">
            <section class="card">
                <h1>About</h1>
                <p>$display_name — built with Erlang, Cowboy, bbmustache, and SQLite.</p>
            </section>
        </div>
    </main>
    <footer class="site-footer">
        <p>&copy; {{year}} {{app_name}}</p>
    </footer>
</body>
</html>
