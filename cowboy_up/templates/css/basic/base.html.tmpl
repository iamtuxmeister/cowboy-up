<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ title }}{% endblock %} — {{ app_name }}</title>
    <link rel="stylesheet" href="/static/css/app.css">
    {% block head %}{% endblock %}
</head>
<body>
    <header class="site-header">
        <nav class="nav">
            <a class="nav-brand" href="/">{{ app_name }}</a>
            <ul class="nav-links">
                <li><a href="/" {% if path == "/" %}class="active"{% endif %}>Home</a></li>
                <li><a href="/about" {% if path == "/about" %}class="active"{% endif %}>About</a></li>
            </ul>
        </nav>
    </header>
    <main class="site-main">
        {% block content %}{% endblock %}
    </main>
    <footer class="site-footer">
        <p>&copy; {{ year }} {{ app_name }}</p>
    </footer>
    <script src="/static/js/app.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
