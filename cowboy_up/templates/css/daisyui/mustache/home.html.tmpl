<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} — {{app_name}}</title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/static/css/app.css">
</head>
<body class="bg-base-200 min-h-screen flex flex-col">
    <div class="navbar bg-base-100 shadow-sm sticky top-0 z-10">
        <div class="navbar-start">
            <a href="/" class="btn btn-ghost text-xl">{{app_name}}</a>
        </div>
        <div class="navbar-end">
            <ul class="menu menu-horizontal px-1">
                <li><a href="/" class="active">Home</a></li>
                <li><a href="/about">About</a></li>
            </ul>
        </div>
    </div>
    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-8">
        <div class="space-y-6">
            <div class="hero bg-base-100 rounded-box py-10">
                <div class="hero-content text-left w-full">
                    <div>
                        <h1 class="text-4xl font-bold">{{title}}</h1>
                        <p class="py-3 text-base-content/60">Erlang + Cowboy + bbmustache + DaisyUI.</p>
                    </div>
                </div>
            </div>
            <div class="card bg-base-100 shadow-sm">
                <div class="card-body">
                    <h2 class="card-title">Example Records</h2>
                    {{#items}}
                    <div class="overflow-x-auto">
                        <table class="table table-zebra">
                            <thead>
                                <tr><th>ID</th><th>Name</th><th>Created</th></tr>
                            </thead>
                            <tbody>
                                {{#items}}
                                <tr>
                                    <td>{{id}}</td>
                                    <td>{{name}}</td>
                                    <td>{{created_at}}</td>
                                </tr>
                                {{/items}}
                            </tbody>
                        </table>
                    </div>
                    {{/items}}
                    {{^items}}
                    <p class="text-base-content/50 italic">No records yet — insert rows into the <code class="kbd kbd-sm">example</code> table.</p>
                    {{/items}}
                </div>
            </div>
        </div>
    </main>
    <footer class="footer footer-center p-4 bg-base-100 text-base-content border-t">
        <aside><p>&copy; {{year}} {{app_name}}</p></aside>
    </footer>
    <script src="/static/js/app.js"></script>
</body>
</html>
