<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error {{status}} — {{app_name}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/static/css/app.css">
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
        <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8">
            <a href="/" class="font-bold text-lg tracking-tight">{{app_name}}</a>
        </nav>
    </header>
    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-10">
        <div class="bg-white border border-gray-200 rounded-lg p-6">
            <h1 class="text-6xl font-bold text-red-500 mb-2">{{status}}</h1>
            <p class="text-gray-500 mb-6">{{message}}</p>
            <a href="/" class="inline-block px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm font-medium">Go home</a>
        </div>
    </main>
</body>
</html>
