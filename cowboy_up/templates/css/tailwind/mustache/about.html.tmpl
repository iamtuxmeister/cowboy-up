<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About — {{app_name}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/static/css/app.css">
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
        <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8">
            <a href="/" class="font-bold text-lg tracking-tight">{{app_name}}</a>
            <ul class="flex gap-6 ml-auto list-none">
                <li><a href="/" class="text-sm text-gray-500 hover:text-gray-900">Home</a></li>
                <li><a href="/about" class="text-sm text-blue-600 font-medium">About</a></li>
            </ul>
        </nav>
    </header>
    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-10">
        <div class="bg-white border border-gray-200 rounded-lg p-6">
            <h1 class="text-2xl font-bold mb-3">About</h1>
            <p class="text-gray-600">$display_name — built with Erlang, Cowboy, bbmustache, and Tailwind CSS.</p>
        </div>
    </main>
    <footer class="border-t border-gray-200 py-4 text-center text-sm text-gray-400">
        &copy; {{year}} {{app_name}}
    </footer>
</body>
</html>
