<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} — {{app_name}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/static/css/app.css">
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
        <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8">
            <a href="/" class="font-bold text-lg tracking-tight">{{app_name}}</a>
            <ul class="flex gap-6 ml-auto list-none">
                <li><a href="/" class="text-sm text-blue-600 font-medium">Home</a></li>
                <li><a href="/about" class="text-sm text-gray-500 hover:text-gray-900">About</a></li>
            </ul>
        </nav>
    </header>
    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-10">
        <div class="space-y-8">
            <section>
                <h1 class="text-4xl font-bold tracking-tight mb-2">{{title}}</h1>
                <p class="text-gray-500 text-lg">Erlang + Cowboy + bbmustache + ${db} + Tailwind CSS.</p>
            </section>
            <section class="bg-white border border-gray-200 rounded-lg p-6">
                <h2 class="text-lg font-semibold mb-4">Example Records</h2>
                {{#items}}
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-2 px-3 text-xs font-semibold uppercase tracking-wide text-gray-400">ID</th>
                            <th class="text-left py-2 px-3 text-xs font-semibold uppercase tracking-wide text-gray-400">Name</th>
                            <th class="text-left py-2 px-3 text-xs font-semibold uppercase tracking-wide text-gray-400">Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#items}}
                        <tr class="border-b border-gray-100 hover:bg-gray-50">
                            <td class="py-2 px-3">{{id}}</td>
                            <td class="py-2 px-3">{{name}}</td>
                            <td class="py-2 px-3 text-gray-400">{{created_at}}</td>
                        </tr>
                        {{/items}}
                    </tbody>
                </table>
                {{/items}}
                {{^items}}
                <p class="text-gray-400 italic">No records yet — insert rows into the <code class="bg-gray-100 px-1 rounded">example</code> table.</p>
                {{/items}}
            </section>
        </div>
    </main>
    <footer class="border-t border-gray-200 py-4 text-center text-sm text-gray-400">
        &copy; {{year}} {{app_name}}
    </footer>
    <script src="/static/js/app.js"></script>
</body>
</html>
