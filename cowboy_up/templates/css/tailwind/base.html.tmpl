<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ title }}{% endblock %} — {{ app_name }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/static/css/app.css">
    {% block head %}{% endblock %}
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
        <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8">
            <a href="/" class="font-bold text-lg tracking-tight">{{ app_name }}</a>
            <ul class="flex gap-6 ml-auto list-none">
                <li>
                    <a href="/"
                       class="text-sm {% if path == "/" %}text-blue-600 font-medium{% else %}text-gray-500 hover:text-gray-900{% endif %}">
                        Home
                    </a>
                </li>
                <li>
                    <a href="/about"
                       class="text-sm {% if path == "/about" %}text-blue-600 font-medium{% else %}text-gray-500 hover:text-gray-900{% endif %}">
                        About
                    </a>
                </li>
            </ul>
        </nav>
    </header>
    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-10">
        {% block content %}{% endblock %}
    </main>
    <footer class="border-t border-gray-200 py-4 text-center text-sm text-gray-400">
        &copy; {{ year }} {{ app_name }}
    </footer>
    <script src="/static/js/app.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
