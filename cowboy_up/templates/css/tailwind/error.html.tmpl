{% extends "layouts/base.html" %}
{% block title %}Error {{ status }}{% endblock %}
{% block content %}
<div class="bg-white border border-gray-200 rounded-lg p-6">
    <h1 class="text-6xl font-bold text-red-500 mb-2">{{ status }}</h1>
    <p class="text-gray-500 mb-6">{{ message }}</p>
    <a href="/" class="inline-block px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm font-medium">Go home</a>
</div>
{% endblock %}
