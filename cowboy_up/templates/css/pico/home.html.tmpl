{% extends "layouts/base.html" %}
{% block content %}
<section>
    <hgroup>
        <h1>{{ title }}</h1>
        <p>Erlang + Cowboy + ErlyDTL + Pico CSS.</p>
    </hgroup>
</section>
<section>
    <h2>Example Records</h2>
    {% if items %}
    <figure>
        <table>
            <thead>
                <tr><th>ID</th><th>Name</th><th>Created</th></tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr>
                    <td>{{ item.id }}</td>
                    <td>{{ item.name }}</td>
                    <td>{{ item.created_at }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </figure>
    {% else %}
    <p><em>No records yet — insert rows into the <code>example</code> table.</em></p>
    {% endif %}
</section>
{% endblock %}
