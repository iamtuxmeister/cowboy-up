-module(${app_name}_app).
-behaviour(application).

-export([start/2, stop/1]).

start(_Type, _Args) ->
    {ok, Env} = application:get_env($app_name, http),
    Port = proplists:get_value(port, Env, 8080),

    ok = ${app_name}_templates:compile_all(),
    ok = ${app_name}_db:init(),

    %% Resolve priv/ from the actual beam file location so static serving
    %% works correctly under both rebar3 shell (dev profile) and releases.
    PrivDir = priv_dir(),

    Dispatch = cowboy_router:compile([
        {'_', [
            {"/",             home_handler,  []},
            {"/about",        page_handler,  [{page, about}]},
            {"/static/[...]", cowboy_static, {dir, filename:join(PrivDir, "static")}}
        ]}
    ]),

    {ok, _} = cowboy:start_clear(http_listener,
        [{port, Port}],
        #{env        => #{dispatch => Dispatch},
          middlewares => [cowboy_router,
                          ${app_name}_logger]}
    ),

    error_logger:info_msg("$app_name started on port ~p~n", [Port]),
    ${app_name}_sup:start_link().

stop(_State) ->
    cowboy:stop_listener(http_listener),
    ${app_name}_db:close(),
    ok.

%% ---------------------------------------------------------------------------
%% Locate the priv/ directory reliably under dev shell and releases.
%%
%% code:priv_dir/1 follows the symlink rebar3 creates in _build/, which
%% points back to the real priv/ in the source tree — so this works in
%% both dev (rebar3 as dev shell) and prod (rebar3 release).
%% ---------------------------------------------------------------------------
priv_dir() ->
    case code:priv_dir($app_name) of
        {error, bad_name} ->
            %% Fallback: derive from this module's beam location
            BeamPath = code:which(?MODULE),
            AppDir   = filename:dirname(filename:dirname(BeamPath)),
            filename:join(AppDir, "priv");
        Dir ->
            Dir
    end.
