%%% Shared handler utilities — bbmustache backend.
-module(${app_name}_handler).

-export([render/3, reply_json/3, reply_error/3, not_found/1, base_ctx/1]).

render(Req, Template, Ctx) ->
    TemplatePath = filename:join([priv_dir(), "templates", Template]),
    FullCtx = maps:merge(base_ctx(Req), Ctx),
    case file:read_file(TemplatePath) of
        {ok, Bin} ->
            Html = bbmustache:render(Bin, convert_ctx(FullCtx),
                                     [{key_type, atom}]),
            cowboy_req:reply(200,
                #{<<"content-type">> => <<"text/html; charset=utf-8">>},
                Html, Req);
        {error, Reason} ->
            error_logger:error_msg("[handler] template ~s not found: ~p~n",
                                   [Template, Reason]),
            reply_error(Req, 500, <<"Template not found">>)
    end.

reply_json(Req, Status, Data) ->
    cowboy_req:reply(Status,
        #{<<"content-type">> => <<"application/json; charset=utf-8">>},
        jsone:encode(Data), Req).

reply_error(Req, Status, Message) ->
    ErrorTemplate = filename:join([priv_dir(), "templates", "error.html"]),
    Ctx = #{status => integer_to_binary(Status), message => Message},
    case file:read_file(ErrorTemplate) of
        {ok, Bin} ->
            cowboy_req:reply(Status,
                #{<<"content-type">> => <<"text/html; charset=utf-8">>},
                bbmustache:render(Bin, Ctx, [{key_type, atom}]), Req);
        _ ->
            cowboy_req:reply(Status,
                #{<<"content-type">> => <<"text/plain">>},
                Message, Req)
    end.

not_found(Req) -> reply_error(Req, 404, <<"Page not found">>).

base_ctx(Req) ->
    {Y, _, _} = date(),
    #{path     => cowboy_req:path(Req),
      app_name => <<"$app_name">>,
      year     => integer_to_binary(Y)}.

%% ---------------------------------------------------------------------------
%% Context conversion
%%
%% bbmustache with {key_type, atom} matches {{variable}} directly against
%% atom keys — no conversion needed for scalar values.
%%
%% Lists of maps (e.g. items from a DB query) need their keys converted
%% from whatever the model returns to atoms so bbmustache can match them.
%% ---------------------------------------------------------------------------

convert_ctx(Map) when is_map(Map) ->
    maps:fold(fun(K, V, Acc) ->
        Acc#{to_atom(K) => convert_value(V)}
    end, #{}, Map).

convert_value(V) when is_map(V)  -> convert_ctx(V);
convert_value(V) when is_list(V) ->
    case is_list_of_maps(V) of
        true  -> [convert_ctx(M) || M <- V];
        false -> V
    end;
convert_value(V) -> V.

to_atom(K) when is_atom(K)   -> K;
to_atom(K) when is_binary(K) -> binary_to_atom(K, utf8);
to_atom(K) when is_list(K)   -> list_to_atom(K).

is_list_of_maps([])      -> false;
is_list_of_maps([H | _]) -> is_map(H).

priv_dir() ->
    case code:priv_dir($app_name) of
        {error, bad_name} ->
            BeamPath = code:which(?MODULE),
            AppDir   = filename:dirname(filename:dirname(BeamPath)),
            filename:join(AppDir, "priv");
        Dir -> Dir
    end.
